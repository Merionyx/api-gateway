FROM golang:1.26.1-alpine AS builder

RUN apk add --no-cache git ca-certificates tzdata

WORKDIR /controller

COPY go.mod go.sum ./

RUN go mod download

# Layer cache: only this component + shared deps (not api-server / sidecar / syncer).
COPY pkg/ pkg/
COPY cmd/controller/ cmd/controller/
COPY internal/shared/ internal/shared/
COPY internal/controller/ internal/controller/

RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o main cmd/controller/main.go

FROM alpine:3.19

RUN apk --no-cache add ca-certificates tzdata

RUN addgroup -g 1001 app && \
    adduser -u 1001 -G app -s /bin/sh -D app

WORKDIR /controller

COPY --from=builder /controller/main .

RUN chown -R app:app /controller

USER app

EXPOSE 8080 8443 8444

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1

CMD ["./main"] 