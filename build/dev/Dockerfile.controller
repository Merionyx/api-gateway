FROM golang:1.26.1-alpine

RUN apk add --no-cache git ca-certificates tzdata curl

RUN curl -sSfL https://raw.githubusercontent.com/cosmtrek/air/master/install.sh | sh -s -- -b /usr/local/bin

WORKDIR /app

COPY go.mod go.sum ./

RUN go mod download

COPY pkg/ pkg/
COPY internal/shared/ internal/shared/
COPY internal/controller/ internal/controller/
COPY cmd/controller/ cmd/controller/
COPY deployments/dev/air/controller.toml deployments/dev/air/controller.toml

EXPOSE 8080 8443 8444

CMD ["air", "-c", "deployments/dev/air/controller.toml"]