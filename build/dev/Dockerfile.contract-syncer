FROM golang:1.26.2-alpine

RUN apk add --no-cache git ca-certificates tzdata curl

RUN curl -sSfL https://raw.githubusercontent.com/cosmtrek/air/master/install.sh | sh -s -- -b /usr/local/bin

WORKDIR /app

COPY go.mod go.sum ./

RUN go mod download

COPY pkg/ pkg/
COPY internal/shared/etcd/ internal/shared/etcd/
COPY internal/shared/git/ internal/shared/git/
COPY internal/contract-syncer/ internal/contract-syncer/
COPY cmd/contract-syncer/ cmd/contract-syncer/
COPY deployments/dev/air/contract-syncer.toml deployments/dev/air/contract-syncer.toml

EXPOSE 8080 8443 8444

CMD ["air", "-c", "deployments/dev/air/contract-syncer.toml"]