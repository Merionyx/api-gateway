FROM golang:1.26.1-alpine

RUN apk add --no-cache git ca-certificates tzdata curl

RUN curl -sSfL https://raw.githubusercontent.com/cosmtrek/air/master/install.sh | sh -s -- -b /usr/local/bin

WORKDIR /app

COPY go.mod go.sum ./

RUN go mod download

COPY pkg/ pkg/
COPY internal/shared/bundlekey/ internal/shared/bundlekey/
COPY internal/shared/election/ internal/shared/election/
COPY internal/shared/etcd/ internal/shared/etcd/
COPY internal/shared/git/ internal/shared/git/
COPY internal/shared/grpcutil/ internal/shared/grpcutil/
COPY internal/api-server/ internal/api-server/
COPY cmd/api-server/ cmd/api-server/
COPY deployments/dev/air/api-server.toml deployments/dev/air/api-server.toml

EXPOSE 8080 8443 8444

CMD ["air", "-c", "deployments/dev/air/api-server.toml"]