
FROM golang:1.26.2-alpine

RUN apk add --no-cache git ca-certificates tzdata curl

RUN curl -sSfL https://raw.githubusercontent.com/cosmtrek/air/master/install.sh | sh -s -- -b /usr/local/bin

WORKDIR /app

COPY go.mod go.sum ./

RUN go mod download

COPY pkg/ pkg/
COPY internal/shared/grpcutil/ internal/shared/grpcutil/
COPY internal/shared/utils/ internal/shared/utils/
COPY internal/auth-sidecar/ internal/auth-sidecar/
COPY cmd/auth-sidecar/ cmd/auth-sidecar/
COPY deployments/dev/air/auth-sidecar.toml deployments/dev/air/auth-sidecar.toml

EXPOSE 8080 8443 8444

CMD ["air", "-c", "deployments/dev/air/auth-sidecar.toml"]